{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "CommonJS",
    "target": "ES2022",
    "moduleResolution": "node",
    "allowJs": false,
    "noImplicitAny": true,
    "sourceMap": false,
    "strict": true,
    "lib": ["DOM", "ES2022"],
    "skipLibCheck": true
  },
  "include": ["main.ts", "git-service.ts", "theme-service.ts", "utils.ts", "declarations.d.ts"],
  "exclude": ["templates/**/*", "node_modules", "main.js"]
}